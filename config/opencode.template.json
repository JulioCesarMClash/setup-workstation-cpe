{
  "$schema": "https://opencode.ai/config.json",
  "model": "${GENTLE_DEFAULT_MODEL}",
  "small_model": "${GENTLE_SMALL_MODEL}",
  "skills": {
    "paths": [
      "${GENTLE_SKILLS_DIR}",
      "${OPENCODE_CONFIG_DIR}/skills"
    ]
  },
  "agent": {
    "gentle-orchestrator": {
      "description": "Gentle AI SDD Orchestrator - coordinates sub-agents, never does work inline",
      "mode": "primary",
      "model": "${GENTLE_ORCHESTRATOR_MODEL}",
      "permission": {
        "question": "allow",
        "task": {
          "*": "deny",
          "jd-fix-agent": "allow",
          "jd-judge-a": "allow",
          "jd-judge-b": "allow",
          "review-readability": "allow",
          "review-reliability": "allow",
          "review-resilience": "allow",
          "review-risk": "allow",
          "sdd-apply": "allow",
          "sdd-archive": "allow",
          "sdd-design": "allow",
          "sdd-explore": "allow",
          "sdd-init": "allow",
          "sdd-onboard": "allow",
          "sdd-propose": "allow",
          "sdd-spec": "allow",
          "sdd-tasks": "allow",
          "sdd-verify": "allow"
        }
      },
      "prompt": "You are the Gentle AI SDD Orchestrator. Coordinate sub-agents, keep user context thin, delegate implementation and broad exploration, and synthesize results. Generated technical artifacts default to English unless the user explicitly requests another artifact language."
    },
    "sdd-explore": {
      "description": "Investigate codebase and think through ideas",
      "hidden": true,
      "mode": "subagent",
      "model": "${SDD_EXPLORE_MODEL}",
      "prompt": "{file:${OPENCODE_CONFIG_DIR}/prompts/sdd/sdd-explore.md}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "sdd-propose": {
      "description": "Create change proposals from explorations",
      "hidden": true,
      "mode": "subagent",
      "model": "${SDD_PROPOSE_MODEL}",
      "prompt": "{file:${OPENCODE_CONFIG_DIR}/prompts/sdd/sdd-propose.md}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "sdd-design": {
      "description": "Create technical design from proposals",
      "hidden": true,
      "mode": "subagent",
      "model": "${SDD_DESIGN_MODEL}",
      "prompt": "{file:${OPENCODE_CONFIG_DIR}/prompts/sdd/sdd-design.md}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "sdd-spec": {
      "description": "Write detailed specifications from proposals",
      "hidden": true,
      "mode": "subagent",
      "model": "${SDD_SPEC_MODEL}",
      "prompt": "{file:${OPENCODE_CONFIG_DIR}/prompts/sdd/sdd-spec.md}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "sdd-tasks": {
      "description": "Break down specs and designs into implementation tasks",
      "hidden": true,
      "mode": "subagent",
      "model": "${SDD_TASKS_MODEL}",
      "prompt": "{file:${OPENCODE_CONFIG_DIR}/prompts/sdd/sdd-tasks.md}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "sdd-apply": {
      "description": "Implement code changes from task definitions",
      "hidden": true,
      "mode": "subagent",
      "model": "${SDD_APPLY_MODEL}",
      "prompt": "{file:${OPENCODE_CONFIG_DIR}/prompts/sdd/sdd-apply.md}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "sdd-verify": {
      "description": "Validate implementation against specs",
      "hidden": true,
      "mode": "subagent",
      "model": "${SDD_VERIFY_MODEL}",
      "prompt": "{file:${OPENCODE_CONFIG_DIR}/prompts/sdd/sdd-verify.md}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "sdd-archive": {
      "description": "Archive completed change artifacts",
      "hidden": true,
      "mode": "subagent",
      "model": "${SDD_ARCHIVE_MODEL}",
      "prompt": "{file:${OPENCODE_CONFIG_DIR}/prompts/sdd/sdd-archive.md}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "review-risk": {
      "description": "Risk and security review",
      "hidden": true,
      "mode": "subagent",
      "model": "${REVIEW_RISK_MODEL}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    },
    "jd-judge-a": {
      "description": "Adversarial judgment-day review",
      "hidden": true,
      "mode": "subagent",
      "model": "${JD_JUDGE_A_MODEL}",
      "tools": { "bash": true, "edit": true, "read": true, "write": true }
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "type": "local",
      "command": ["engram", "mcp", "--tools=agent"]
    },
    "obsidian": {
      "type": "local",
      "enabled": ${OBSIDIAN_ENABLED_JSON},
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "${OBSIDIAN_VAULT_PATH}"]
    },
    "obsidian-semantic": {
      "type": "remote",
      "enabled": ${OBSIDIAN_SEMANTIC_ENABLED_JSON},
      "url": "${OBSIDIAN_SEMANTIC_URL}",
      "headers": {
        "Authorization": "Bearer ${OBSIDIAN_SEMANTIC_TOKEN}"
      }
    },
    "jira": {
      "type": "local",
      "enabled": ${JIRA_ENABLED_JSON},
      "command": ["${MCP_ATLASSIAN_BIN}"],
      "environment": {
        "JIRA_URL": "${JIRA_URL}",
        "JIRA_USERNAME": "${JIRA_USERNAME}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}",
        "CONFLUENCE_URL": "${CONFLUENCE_URL}",
        "CONFLUENCE_USERNAME": "${CONFLUENCE_USERNAME}",
        "CONFLUENCE_API_TOKEN": "${CONFLUENCE_API_TOKEN}"
      }
    },
    "headroom": {
      "type": "local",
      "enabled": ${HEADROOM_ENABLED_JSON},
      "command": ["${HEADROOM_BIN}", "mcp", "serve", "--proxy-url", "${HEADROOM_PROXY_URL}"],
      "environment": {
        "HF_HUB_OFFLINE": "1"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/.aws/credentials": "deny",
      "**/.config/gh/hosts.yml": "deny",
      "**/.credentials/**": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.ssh/**": "deny",
      "**/Library/Keychains/**": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "provider": {
    "ollama": {
      "api": "${OLLAMA_API}",
      "models": ${OLLAMA_MODELS_JSON}
    }
  },
  "share": "disabled"
}
