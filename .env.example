GENTLE_HOME="$HOME"
OPENCODE_CONFIG_DIR="$HOME/.config/opencode"
GENTLE_SKILLS_DIR="$HOME/.skills"

# Local models
OLLAMA_API="http://localhost:11434/v1"
GENTLE_DEFAULT_MODEL="ollama/gemma4:31b"
GENTLE_SMALL_MODEL="ollama/qwen2.5-coder:14b"
GENTLE_ORCHESTRATOR_MODEL="opencode/deepseek-v4-flash-free"
SDD_EXPLORE_MODEL="ollama/gemma4:31b"
SDD_PROPOSE_MODEL="opencode-go/glm-5.2"
SDD_DESIGN_MODEL="opencode/deepseek-v4-flash-free"
SDD_SPEC_MODEL="opencode-go/qwen3.7-plus"
SDD_TASKS_MODEL="ollama/gemma4:31b"
SDD_APPLY_MODEL="opencode-go/deepseek-v4-pro"
SDD_VERIFY_MODEL="opencode-go/deepseek-v4-pro"
SDD_ARCHIVE_MODEL="ollama/qwen2.5-coder:14b"
REVIEW_RISK_MODEL="ollama/gemma4:31b"
JD_JUDGE_A_MODEL="ollama/gemma4:31b"
OLLAMA_MODELS_JSON="{\"gemma4:31b\": {\"tool_call\": true}, \"qwen2.5-coder:14b\": {\"tool_call\": true}}"

# Optional local paths
OBSIDIAN_VAULT_PATH=""
CLAUDE_CODE_PATH="claude"
CLAUDE_CODE_ENABLED="false"
HEADROOM_BIN="headroom"
HEADROOM_PROXY_URL="http://127.0.0.1:8787"
HEADROOM_ENABLED_JSON="false"
OBSIDIAN_ENABLED_JSON="false"
OBSIDIAN_SEMANTIC_ENABLED_JSON="false"
JIRA_ENABLED_JSON="false"

# Optional remote/local MCPs
OBSIDIAN_SEMANTIC_URL="http://localhost:3001/mcp"
OBSIDIAN_SEMANTIC_TOKEN=""
MCP_ATLASSIAN_BIN="/opt/homebrew/opt/mcp-atlassian/bin/mcp-atlassian"

# Jira / Confluence. Never commit real values.
JIRA_URL=""
JIRA_USERNAME=""
JIRA_API_TOKEN=""
CONFLUENCE_URL=""
CONFLUENCE_USERNAME=""
CONFLUENCE_API_TOKEN=""

# Optional Postgres MCP DSN. Prefer read-only users.
POSTGRES_MCP_DSN=""
POSTGRES_MCP_SSH_HOST=""
